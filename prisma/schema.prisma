generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Area {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(255)
  description String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamp(6)

  // Relaciones
  branchId String   @map("branch_id") @db.Uuid
  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  devices  Device[]

  @@map("areas")
}

model Branch {
  id           String    @id @default(uuid()) @db.Uuid
  name         String    @db.VarChar(255)
  address      String?
  contactName  String?   @map("contact_name") @db.VarChar(255)
  contactPhone String?   @map("contact_phone") @db.VarChar(20)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamp(6)

  // Relaciones
  customerId String   @map("customer_id") @db.Uuid
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  areas      Area[]

  @@map("branches")
}

model Customer {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(255)
  logoUrl   String?   @map("logo_url")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(6)

  // Relaciones
  branches      Branch[]
  subscriptions Subscription[]

  @@map("customers")
}

model DeviceMetadata {
  id        String    @id @default(uuid()) @db.Uuid
  field     String    @db.VarChar(255)
  value     String
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(6)

  // Relaciones
  deviceId String @map("device_id") @db.Uuid
  device   Device @relation(fields: [deviceId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("device_metadata")
}

model Device {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(255)
  type      String    @db.VarChar(255)
  serial    String?   @db.VarChar(255)
  username  String?   @db.VarChar(255)
  password  String?   @db.VarChar(255)
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(6)

  // Relaciones
  areaId   String           @map("area_id") @db.Uuid
  area     Area             @relation(fields: [areaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  metadata DeviceMetadata[]

  @@map("devices")
}

model Subscription {
  id                String   @id @default(uuid()) @db.Uuid
  serviceName       String   @map("service_name") @db.VarChar
  externalAccountId String?  @map("external_account_id") @db.VarChar
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relaciones
  customerId String?   @map("customer_id") @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("subscriptions")
}

model User {
  id               String    @id @default(uuid()) @db.Uuid
  firstName        String    @map("first_name") @db.VarChar(255)
  lastName         String    @map("last_name") @db.VarChar(255)
  email            String    @unique @db.VarChar(150)
  passwordHash     String    @map("password_hash") @db.VarChar
  role             UserRole  @default(viewer)
  isActive         Boolean   @default(true) @map("is_active")
  refreshTokenHash String?   @map("refresh_token_hash")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamp(6)

  @@map("users")
}

enum UserRole {
  super_admin
  admin
  operator
  viewer

  @@map("users_role_enum")
}
